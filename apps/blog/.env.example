NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SITE_URL=https://your-blog.vercel.app
# 서브도메인 간 세션 공유를 위한 쿠키 도메인 (예: .noopdaa.blog)
NEXT_PUBLIC_COOKIE_DOMAIN=

# Email notification settings (get API key from https://resend.com)
RESEND_API_KEY=your-resend-api-key
ADMIN_EMAIL=youremail@domain.com
EMAIL_FROM=Blog <noreply@domain.com>

# 서브도메인 간 세션 공유를 위한 쿠키 도메인 (예: .noopdaa.blog)
NEXT_PUBLIC_COOKIE_DOMAIN=.noopdaa.blog

NEXT_PUBLIC_NAVER_SITE_VERIFICATION=your_code